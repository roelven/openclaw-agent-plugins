{
  "id": "vector-memory",
  "name": "Vector Memory",
  "kind": "memory",
  "version": "1.0.0",
  "description": "Local vector-based memory with automatic fact extraction and context injection using Ollama embeddings",
  "main": "index.ts",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "database": {
        "type": "string",
        "default": "~/.openclaw/memory/vectors.db"
      },
      "embedding": {
        "type": "object",
        "properties": {
          "provider": { "type": "string", "enum": ["ollama"], "default": "ollama" },
          "model": { "type": "string", "default": "nomic-embed-text" },
          "baseUrl": { "type": "string", "default": "http://127.0.0.1:11434" }
        }
      },
      "autoExtract": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "maxPerSession": { "type": "number", "default": 10 },
          "minImportance": { "type": "number", "default": 0.4 }
        }
      },
      "recall": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "limit": { "type": "number", "default": 5 },
          "minScore": { "type": "number", "default": 0.2 }
        }
      }
    }
  }
}
